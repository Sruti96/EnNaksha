# Option A (recommended): Google Sheets API service account
GOOGLE_SHEETS_SPREADSHEET_ID=1SdKIPpEnjmcQCTDpd1cZCg_pg_Q1-h2ljlzmRF2esZI
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option B (fallback): Google Apps Script Web App URL
# Deploy scripts/google-apps-script/leads.gs with access set to Anyone
LEADS_SHEET_API=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Claude API — powers the 2D floor plan generator (/api/design)
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Places API — powers the location autocomplete dropdown on the
# lead form (/api/places/autocomplete). Requires a Google Cloud project
# with the "Places API" enabled and billing set up:
# https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# Restrict this key to server-side use (HTTP referrer restrictions won't
# work since it's called from our server, not the browser — use an IP
# restriction or leave unrestricted but keep it out of client-side code).
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# WhatsApp Cloud API (Meta) — sends an automatic WhatsApp confirmation to a
# lead's number when they finish the enquiry form (/api/leads).
# Setup (all done in Meta's own dashboards, not here):
#   1. developers.facebook.com -> My Apps -> Create App (Business type)
#   2. Add Product -> WhatsApp -> API Setup panel gives you the Phone Number ID
#      and WhatsApp Business Account ID
#   3. Business Settings -> System users -> create one, assign it "Manage
#      WhatsApp Business accounts" + "Manage app" full control on this app,
#      then Generate token there for a PERMANENT access token (the token
#      shown directly on the API Setup panel expires in 24h)
#   4. Submit a message template for approval (Account tools -> Message
#      Templates) -- required for the first message to someone who hasn't
#      messaged you first. Approved template body (name: lead_confirmation):
#      "Hi {{1}}, thanks for reaching out to EnNaksha! We've received your
#      enquiry, and our design team will connect with you on WhatsApp within
#      24 hours to discuss your requirements and provide a free initial
#      design consultation." Uses the single {{1}} = first-name parameter
#      this integration sends.
WHATSAPP_ACCESS_TOKEN=your-permanent-system-user-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_TEMPLATE_NAME=lead_confirmation
WHATSAPP_TEMPLATE_LANG=en

# SendGrid — sends an automatic confirmation email to the address a lead
# enters on the form (/api/leads). Setup:
#   1. signup.sendgrid.com -> create an account
#   2. Settings -> Sender Authentication -> verify a single sender email
#      (fastest) or authenticate your whole domain via DNS records (better
#      deliverability, recommended once you're past testing)
#   3. Settings -> API Keys -> Create API Key -> "Restricted Access" with
#      Mail Send permission only
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=hello@yourdomain.com
SENDGRID_FROM_NAME=EnNaksha
