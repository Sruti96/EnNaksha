# Option A (recommended): Google Sheets API service account
GOOGLE_SHEETS_SPREADSHEET_ID=1SdKIPpEnjmcQCTDpd1cZCg_pg_Q1-h2ljlzmRF2esZI
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option B (fallback): Google Apps Script Web App URL
# Deploy scripts/google-apps-script/leads.gs with access set to Anyone
LEADS_SHEET_API=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Claude API — powers the 2D floor plan generator (/api/design)
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Places API — powers the location autocomplete dropdown on the
# lead form (/api/places/autocomplete). Requires a Google Cloud project
# with the "Places API" enabled and billing set up:
# https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# Restrict this key to server-side use (HTTP referrer restrictions won't
# work since it's called from our server, not the browser — use an IP
# restriction or leave unrestricted but keep it out of client-side code).
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
